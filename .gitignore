# ── DEPENDENCIES ──
# Never track node_modules as they can be regenerated via npm install
node_modules/
jspm_packages/

google-api-file.json

# ── SECRETS & CONFIG ──
# Local environment variables containing sensitive keys/passwords
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── BUILD & OUTPUT ──
# If you use TypeScript or a build step
dist/
build/
out/
.next/

# ── LOGS ──
# Logs generated by the application or npm
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── TESTING ──
# Coverage reports from Jest or other tools
coverage/
.nyc_output/

# ── OS SPECIFIC ──
# System files that provide no value to the code
.DS_Store
Thumbs.db
desktop.ini

# ── IDE/EDITOR ──
# Settings specific to your editor (VS Code, WebStorm, etc.)
.vscode/
.idea/
*.swp
*.swo

# ── DATABASE/TEMP ──
# Local database files or temporary cache
.sqlite
.cache/